# MongoDB connection string for external database
MONGO_URI=mongodb://host.docker.internal:27017/librechat

# Application port (optional, if used in your app)
PORT=9087

# Time in ms to refresh metrics
REFRESH_INTERVAL=30000

# Path to Google Cloud Service Account JSON key file (required for authentication)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# Google Cloud Project ID (required for category metrics)
VERTEX_AI_PROJECT_ID=your-gcp-project-id

# Vertex AI location/region
VERTEX_AI_LOCATION=us-central1

# Gemini model to use for classification
VERTEX_AI_MODEL=gemini-2.5-flash

# Batch size for conversation classification (number of conversations per batch)
CATEGORY_BATCH_SIZE=10

# Delay between classification batches in milliseconds (for rate limiting)
CATEGORY_BATCH_DELAY_MS=100

# Path to the category cache file (for persisting classifications across restarts)
CATEGORY_CACHE_FILE=./data/category-cache.json

# Path to local CSV file with conversations (optional, bypasses MongoDB when set)
# CSV format: _id,title
LOCAL_CONVERSATIONS_CSV=